<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Expense Tracker</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>
  <div class="app-shell">
    <header class="app-topbar">
      <h1>Expense Tracker</h1>
      <div class="topbar-user">
        <span class="topbar-user-copy">Signed in as <strong><%= currentUser ? currentUser.fullName : 'Guest' %></strong></span>
      </div>
    </header>

    <aside class="sidebar">
      <div class="profile-card">
        <div class="avatar-circle"><%= currentUserInitials %></div>
        <h2><%= currentUser ? currentUser.fullName : 'Expense Tracker' %></h2>
        <% if (currentUser) { %>
          <p class="profile-subcopy"><%= currentUser.email %></p>
        <% } %>
      </div>

      <nav class="sidebar-nav">
        <a href="/dashboard" class="nav-item <%= page === 'dashboard' ? 'active' : '' %>">
          <i class='bx bx-grid-alt'></i>
          <span>Dashboard</span>
        </a>
        <a href="/income" class="nav-item <%= page === 'income' ? 'active' : '' %>">
          <i class='bx bx-wallet'></i>
          <span>Income</span>
        </a>
        <a href="/expense" class="nav-item <%= page === 'expense' ? 'active' : '' %>">
          <i class='bx bx-money-withdraw'></i>
          <span>Expense</span>
        </a>
        <a href="/settings" class="nav-item <%= page === 'settings' ? 'active' : '' %>">
          <i class='bx bx-cog'></i>
          <span>Settings</span>
        </a>
        <a href="/logout" class="nav-item">
          <i class='bx bx-log-out'></i>
          <span>Logout</span>
        </a>
      </nav>
    </aside>

    <main class="main-content">
      <% if (flash && flash.message) { %>
        <div class="toast <%= flash.type === 'error' ? 'error' : 'success' %>" data-auto-toast>
          <span class="toast-icon"><i class='bx <%= flash.type === 'error' ? 'bx-error-circle' : 'bx-check-circle' %>'></i></span>
          <span><%= flash.message %></span>
        </div>
      <% } %>
